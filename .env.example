# ------------------------------
# App Configuration
# ------------------------------
# Environment: 'development' or 'production' (disables swagger)
ENV=development
# Port to bind the HTTP server
PORT=8080

# ------------------------------
# Database Configuration
# ------------------------------
DATABASE_URL=postgres://postgres:password@localhost:5432/media?sslmode=disable
# Toggle automatic migrations on startup
AUTO_MIGRATE=true
# Path to migration files
MIGRATION_PATH=file://migrations

# ------------------------------
# S3 / Object Storage Configuration
# ------------------------------
# Endpoint for S3 API (e.g., s3.amazonaws.com, localhost:9010)
S3_ENDPOINT=localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Bucket name (must exist or be created by infra)
S3_BUCKET=media-blobs
# Region (usually required for AWS, optional for MinIO)
S3_REGION=us-east-1
# Set to 'true' if using HTTPS (AWS S3), 'false' for local MinIO over HTTP
S3_USE_SSL=false

# ------------------------------
# Garbage Collection
# ------------------------------
# How often the GC worker sweeps orphaned blobs
GC_SWEEP_INTERVAL=10m
# How long a blob must be orphaned before being deleted
GC_GRACE_PERIOD=24h

# ------------------------------
# Presigned URL Expiry
# ------------------------------
# How long multipart upload presigned URLs remain valid
PRESIGNED_UPLOAD_EXPIRY=24h
# How long download presigned URLs remain valid
PRESIGNED_DOWNLOAD_EXPIRY=1h
